# Kite Connect (Zerodha) - for Orders & Quotes
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
KITE_ACCESS_TOKEN=your_kite_access_token

# Fyers API v3 Credentials - for Signal Data (Candles)
FYERS_ID=your_fyers_id
FYERS_APP_ID=your_fyers_app_id
FYERS_SECRET_KEY=your_fyers_secret_key
FYERS_REDIRECT_URI=https://trade.fyers.in/api-login/redirect-uri/index.html

# Optional: Paste access token here to skip daily browser login
# Generate once via browser, valid for one day
FYERS_ACCESS_TOKEN=your_fyers_access_token

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Trading Configuration
SYMBOL=NSE:NIFTY50-INDEX
EMA_PERIOD=5
SCAN_START_TIME=09:25
SCAN_END_TIME=15:15

# Trade Execution Settings
TRADING_ENABLED=true
PAPER_TRADING=true

# Trade Timing
# Entries allowed from 09:30 (skip only the first 15 min after the 09:15 open).
# The 10:00 start filter was removed Jun 27 — the post-implementation tally showed
# it blocked more would-be winners than the losers it avoided. See LEARNINGS.md §7b.
# Scanning still starts 09:25 so EMA/VWAP are warmed up by entry time.
TRADE_START_TIME=09:30
TRADE_END_TIME=14:30
FORCE_CLOSE_TIME=15:15

# Trade Parameters
MAX_TRADES_PER_DAY=1
TARGET_POINTS=80
STOPLOSS_POINTS=25
LOT_SIZE=65

# Option Selection
STRIKE_MODE=delta
# delta   = Target delta ~0.7 (150 ITM), faster profits
# premium = Target premium >= 220, safer liquidity

MIN_PREMIUM=220
ITM_OFFSET_FOR_DELTA=150
MAX_ITM_OFFSET=300
